# ── Agent Identity ───────────────────────────────────────────────────────────
# UID of this agent instance — must match a uid in harness/agent-registry.yml.
#   optimizer-001  (Claude — requirement design, TC review, TC impl, feature impl)
#   evaluator-001  (Claude separate session / Codex — req review, TC design, code review)
#   human-001      (Daniel — scope approval, final merge, escalation resolution)
AGENT_UID=optimizer-001

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=changeme
# Proxy endpoint — set to https://api.anthropic.com for direct access
ANTHROPIC_API_BASE=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-6

# ── Data Pipeline ─────────────────────────────────────────────────────────────
# AkShare / Tushare (optional, for data sources that require tokens)
TUSHARE_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────
DUCKDB_PATH=data/db/aidc.duckdb

# ── Phase 8a: Neo4j Knowledge Graph ──────────────────────────────────────────
# Introduced in Phase 8a. Not required for Phases 0–7.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=my-invest-dev

# ── Phase 8b: LanceDB RAG ────────────────────────────────────────────────────
# Introduced in Phase 8b. Not required for Phases 0–7.
LANCEDB_PATH=data/lancedb
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Phase 9: LangGraph Agent ──────────────────────────────────────────────────
# Introduced in Phase 9. Not required for Phases 0–8.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=my-invest-global

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
